# Auto-detect text files and normalise line endings
* text=auto

# Markdown and config: always LF
*.md text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.sql text eol=lf

# Source code: LF
*.rs text eol=lf
*.toml text eol=lf

# Shell scripts: LF
*.sh text eol=lf

# PowerShell scripts: CRLF (Windows convention)
*.ps1 text eol=crlf

# Binary files: never diff or merge
*.db binary
*.sqlite binary
