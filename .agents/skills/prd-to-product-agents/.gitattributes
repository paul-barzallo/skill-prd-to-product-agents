# Auto-detect text files and normalise line endings
* text=auto

# Markdown and config: always LF
*.md text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.jsonc text eol=lf
*.sql text eol=lf
*.sha256 text eol=lf

# Shell scripts: LF
*.sh text eol=lf

# PowerShell scripts: CRLF (Windows convention)
*.ps1 text eol=crlf

# Binary files: never diff or merge
*.db binary
*.sqlite binary

# Published binaries: never apply text conversion on checkout
bin/prd-to-product-agents-cli-* binary
templates/workspace/.agents/bin/prd-to-product-agents/prdtp-agents-functions-cli-* binary

# Export-ignore: exclude from git archive / ZIP distributions
.bootstrap-overlays/ export-ignore
.state/ export-ignore
*.new export-ignore
.mypy_cache/ export-ignore
